@{
    var controller = ViewContext.RouteData.Values["controller"]?
        .ToString()?
        .ToLower()
        ?? String.Empty;
    var area = ViewContext.RouteData.Values["area"]?
        .ToString()?
        .ToLower()
        ?? String.Empty;
}

<a class="navbar-brand badge bg-secondary text-white me-3"
   asp-controller="home"
   asp-action="index">Novskiy</a>

<div class="navbar-nav me-auto">
    <a class="nav-item nav-link @(controller == "home" ? "active" : "")"
       asp-controller="home"
       asp-action="index">Лб1</a>
    <a class="nav-item nav-link @(controller == "product" ? "active" : "")"
       asp-controller="product"
       asp-action="index">Каталог</a>
    <a class="nav-item nav-link @(area == "admin" ? "active" : "")"
       asp-area="admin"
       asp-page="/index">Администрирование</a>
</div>
