@page
@model Novskiy.UI.Areas.Admin.Pages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Create New
    </a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Dish.FirstOrDefault()!.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Dish.FirstOrDefault()!.Description)</th>
            <th>@Html.DisplayNameFor(model => model.Dish.FirstOrDefault()!.Calories)</th>
            <th>@Html.DisplayNameFor(model => model.Dish.FirstOrDefault()!.Image)</th>
            <th>@Html.DisplayNameFor(model => model.Dish.FirstOrDefault()!.Category)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if(Model.Dish != null)
        {
            @foreach (var item in Model.Dish)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                    <td>@Html.DisplayFor(modelItem => item.Calories)</td>
                    <td>
                        <img src="@item.Image" alt="@item.Name" width="50" />
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Category.Name)</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-success">
                            <i class="fa-solid fa-pen-to-square"></i> Edit
                        </a>
                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger">
                            <i class="fa-regular fa-trash-can"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<pager admin="true" current-page="@Model.CurrentPage" total-pages="@Model.TotalPages"></pager>
